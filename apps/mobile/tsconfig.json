{
  "extends": "@baki/config/tsconfig/expo",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@baki/db": ["../../packages/db/src/index.ts"],
      "@baki/i18n": ["../../packages/i18n/src/index.ts"],
      "@baki/payments": ["../../packages/payments/src/index.ts"],
      "@baki/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["nativewind/types", "node", "react"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
