{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "dev:tunnel": "expo start --go --tunnel --port 8081",
    "dev:go": "expo start --go --host lan --port 8081",
    "dev:devclient": "expo start --dev-client --host lan --port 8081",
    "check:assets": "node scripts/check-assets.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "build:android:preview:e2e": "eas build --profile preview-e2e --platform android",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:devclient": "eas build --profile development:device --platform ios",
    "build:ios:devclient:sim": "eas build --profile development --platform ios",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/watermelondb",
          "@nozbe/simdjson"
        ],
        "listUnknownPackages": true
      }
    }
  },
  "dependencies": {
    "@baki/i18n": "workspace:*",
    "@baki/payments": "workspace:*",
    "@baki/ui": "workspace:*",
    "@expo-google-fonts/hind-siliguri": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "~5.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@nozbe/watermelondb": "^0.28.0",
    "@sentry/react-native": "^7.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "dayjs": "^1.11.19",
    "expo": "~54.0.34",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "i18next": "^25.7.2",
    "lucide-react-native": "^0.554.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.3.5",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "~3.3.3",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "~3.4.19",
    "zod": "^4.1.13",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@baki/config": "workspace:*",
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/node": "^24.10.0",
    "@types/react": "~19.1.17",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
