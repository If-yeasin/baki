{
  "name": "baki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/watermelondb",
          "@nozbe/simdjson"
        ],
        "listUnknownPackages": true
      }
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "i18n:check": "pnpm --filter @baki/i18n check",
    "db:check": "pnpm --filter @baki/db test",
    "e2e": "echo \"Run \\`maestro test e2e/maestro\\` manually after starting the dev server\"",
    "e2e:auth:check": "pnpm --filter mobile test -- src/features/e2e",
    "release:safety": "node scripts/check-release-safety.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm i18n:check && pnpm db:check && pnpm --filter mobile check:assets && pnpm release:safety"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
